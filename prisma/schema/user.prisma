model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  name       String?
  posts      Post[]
  profile    Profile?
  arrayField String[] @default([])
}

model Profile {
  id     Int     @id @default(autoincrement())
  bio    String?
  user   User    @relation(fields: [userId], references: [id])
  userId Int     @unique
}
