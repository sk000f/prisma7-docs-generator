{
  "name": "prisma7-docs-generator",
  "version": "7.0.3",
  "main": "dist/index.js",
  "license": "MIT",
  "bin": {
    "prisma7-docs-generator": "dist/cli.js"
  },
  "description": "Documentation reference generator for Prisma 7 schemas (fork of prisma-docs-generator, updated for Prisma ORM 7 and multi-file schemas)",
  "author": "Mike Skaife <mike.skaife@gmail.com>",
  "contributors": [
    "Harshit Pant <pantharshit00@gmail.com> (https://harshitpant.com)"
  ],
  "keywords": [
    "prisma",
    "prisma7",
    "prisma-generator",
    "prisma-schema",
    "code-generation",
    "docs",
    "reference"
  ],
  "homepage": "https://github.com/sk000f/prisma7-docs-generator",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sk000f/prisma7-docs-generator.git"
  },
  "bugs": {
    "url": "https://github.com/sk000f/prisma7-docs-generator/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@prisma/generator-helper": "^7.7.0",
    "@prisma/internals": "^7.7.0",
    "express": "^4.18.2",
    "indent-string": "^5.0.0",
    "kleur": "^4.1.5",
    "meow": "9",
    "pluralize": "^8.0.0",
    "prismjs": "^1.29.0",
    "puppeteer": "^24.40.0",
    "ts-toolbelt": "^9.6.0"
  },
  "devDependencies": {
    "@prisma/client": "^7.7.0",
    "@types/express": "4.17.17",
    "@types/jest": "^29.5.1",
    "@types/node": "^20.1.7",
    "@types/prismjs": "^1.26.0",
    "cpy-cli": "^4.2.0",
    "jest": "^29.5.0",
    "prettier": "^2.8.8",
    "prisma": "^7.7.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4"
  },
  "scripts": {
    "generate": "prisma generate",
    "clean": "rimraf dist && rimraf styles_generator/dist && rimraf src/styles/main.css",
    "build:gen": "tsc -d && cpy --flat src/styles dist/styles",
    "build:styles": "cd styles_generator && yarn build && cpy --flat ./dist/main.css ../src/styles/",
    "build": "yarn build:styles && yarn build:gen",
    "test": "jest",
    "format": "prettier --ignore-path .gitignore src/**/*.ts --write",
    "prepublishOnly": "yarn clean && yarn build && yarn test"
  }
}
